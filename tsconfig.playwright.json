{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["@playwright/test", "node"]
  },
  "include": [
    "src/playwright.config.ts",
    "src/tests/**/*.ts",
    "scripts/assets/playwright.config.ts",
    "scripts/assets/tests/**/*.ts"
  ]
}
