# Example environment variables
# Local dev: copy to .env.local (never commit secrets).
# Production: set in Vercel project env (see `vercel env ls production`).

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
# Must match the port you actually use for `npm run dev` (Next may use 3001/3003 if 3000 is busy).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Supabase Dashboard → Auth → URL Configuration:
# - Site URL: same origin as NEXT_PUBLIC_APP_URL (e.g. http://localhost:3003)
# - Redirect URLs (add every port you use): http://localhost:3003/auth/confirm
# https://your-production-domain/auth/confirm
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# Environment
NODE_ENV=development

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_or_test_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_price_id

# Resend Configuration
RESEND_API_KEY=re_your_resend_api_key
# Verified sender in Resend (production: verify ramply.org domain first)
RESEND_FROM=Ramply <noreply@ramply.org>

# Optional: wire reportServerError() to Sentry/Datadog when implemented
# MONITORING_DSN=

# Anthropic (document classification)
ANTHROPIC_API_KEY=sk-ant-your_key

# OCR (Google Document AI)
OCR_PROVIDER=google_document_ai
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your_processor_id
# Optional explicit prediction endpoint.
GOOGLE_DOCUMENT_AI_ENDPOINT=https://us-documentai.googleapis.com/v1/projects/your_project_id/locations/us/processors/your_processor_id:process
# Raw JSON or base64-encoded service account JSON.
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON=base64_or_json_service_account

# Vercel Configuration (production)
VERCEL_ENV=production
VERCEL_URL=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
